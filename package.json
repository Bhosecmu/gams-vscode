{
  "name": "gams-vscode",
  "displayName": "GAMS",
  "description": "GAMS language support: syntax highlighting, GDX/ref viewer, run integration, and error diagnostics",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "gams",
        "aliases": ["GAMS", "gams"],
        "extensions": [".gms", ".gams"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gams",
        "scopeName": "source.gams",
        "path": "./syntaxes/gams.tmLanguage.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "gams.gdxViewer",
        "displayName": "GDX Viewer",
        "selector": [{ "filenamePattern": "*.gdx" }],
        "priority": "default"
      },
      {
        "viewType": "gams.refViewer",
        "displayName": "GAMS Reference Viewer",
        "selector": [{ "filenamePattern": "*.ref" }],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "gams.run",
        "title": "Run GAMS File",
        "category": "GAMS",
        "icon": "$(play)"
      },
      {
        "command": "gams.stop",
        "title": "Stop GAMS Run",
        "category": "GAMS",
        "icon": "$(stop)"
      }
    ],
    "keybindings": [
      {
        "command": "gams.run",
        "key": "ctrl+f5",
        "when": "editorLangId == gams && !gams.running"
      },
      {
        "command": "gams.stop",
        "key": "shift+f5",
        "when": "editorLangId == gams && gams.running"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "gams.run",
          "when": "editorLangId == gams && !gams.running",
          "group": "navigation"
        },
        {
          "command": "gams.stop",
          "when": "editorLangId == gams && gams.running",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "gams.run",
          "when": "editorLangId == gams",
          "group": "gams@1"
        }
      ]
    },
    "configuration": {
      "title": "GAMS",
      "properties": {
        "gams.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to the GAMS executable (e.g. C:\\GAMS\\47\\gams.exe). Leave empty to auto-detect."
        },
        "gams.defaultScratchDir": {
          "type": "string",
          "default": "",
          "description": "Working directory for GAMS runs. Defaults to the directory of the active file."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0"
  }
}
